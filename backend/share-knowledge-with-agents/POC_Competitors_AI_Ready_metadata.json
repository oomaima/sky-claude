          "tableName": "POC Data",
          "expression": "DIVIDE([_Supplier Costs],[_ASKs])*100",
          "formatString": "#,##0.00\" c\"",
          "dataType": "Double",
          "description": "Measures operating costs per available seat kilometre, considering costs related to third-party services and external suppliers. (Cost per Available Seat Kilometre)",
          "displayFolder": "CASK",
          "isHidden": false,
          "state": "Ready",
          "outputName": "CASK Supplier"
        },
        {
          "name": "_CASK Ownership",
          "tableName": "POC Data",
          "expression": "DIVIDE([_Ownership Costs],[_ASKs])*100",
          "formatString": "#,##0.00\" c\"",
          "dataType": "Double",
          "description": "Measures operating costs per available seat kilometre, associated with aircraft ownership. (Cost per Available Seat Kilometre)",
          "displayFolder": "CASK",
          "isHidden": false,
          "state": "Ready",
          "outputName": "CASK Ownership"
        },
        {
          "name": "_CASK exFuel",
          "tableName": "POC Data",
          "expression": "DIVIDE(([_Ownership Costs]+[_Employee Costs]+[_Supplier Costs]),[_ASKs])*100",
          "formatString": "#,##0.00\" c\"",
          "dataType": "Double",
          "description": "Airline financial metric that measures operating costs per available seat kilometre, excluding fuel expenses. (Cost per Available Seat Kilometre)",
          "displayFolder": "CASK",
          "isHidden": false,
          "state": "Ready",
          "outputName": "CASK exFuel"
        },
        {
          "name": "_OTP 15D",
          "tableName": "POC Data",
          "expression": "\nCALCULATE(SUM('POC Data'[Flights_15D])/SUM('POC Data'[Flights_Departure]))",
          "formatString": "0.0 %;-0.0 %;0.0 %",
          "dataType": "Double",
          "description": "OnTime Performance on Departures (15 minutes) measures the proportion of flights that depart within 15 minutes of their scheduled departure time during a selected period. This KPI reflects the airline's operational punctuality and reliability in departures. A higher OTP indicates effective flight preparation, ground handling, and adherence to the published schedule, contributing to operational efficiency and passenger satisfaction.",
          "displayFolder": "Operations",
          "isHidden": false,
          "state": "Ready",
          "outputName": "OTP 15D"
        },
        {
          "name": "_OTP 180A",
          "tableName": "POC Data",
          "expression": "\nCALCULATE(SUM('POC Data'[Flights_180A])/SUM('POC Data'[Flights_Arrival]))",
          "formatString": "0.0 %;-0.0 %;0.0 %",
          "dataType": "Double",
          "description": "OnTime Performance on Arrival (180 minutes) measures the proportion of flights that arrive within 180 minutes of their scheduled arrival time during a selected period. Delays beyond 180 minutes are particularly relevant, as they may trigger passenger compensations. This KPI reflects the airline's operational punctuality and reliability in arrivals. A higher OTP indicates effective flight preparation, ground handling, and adherence to the published schedule, contributing to operational efficiency and passenger satisfaction.",
          "displayFolder": "Operations",
          "isHidden": false,
          "state": "Ready",
          "outputName": "OTP 180A"
        },
        {
          "name": "_Regularity",
          "tableName": "POC Data",
          "expression": "\nCALCULATE((SUM('POC Data'[Flights])-(SUM('POC Data'[Cancellations])))/SUM('POC Data'[Flights]))",
          "formatString": "0.0 %;-0.0 %;0.0 %",
          "dataType": "Double",
          "description": "Regularity measures the proportion of scheduled flights that are operated (non cancelled) by the airline within a selected period. It reflects the airline's reliability in executing its planned schedule, providing insight into operational stability and consistency. A high regularity indicates that the airline is effectively meeting its published flight commitments",
          "displayFolder": "Operations",
          "isHidden": false,
          "state": "Ready",
          "outputName": "Regularity"
        },
        {
          "name": "_Net debt",
          "tableName": "POC Data",
          "expression": "\nVAR SelectedYear =\n    MAX('POC Data'[Year])\nVAR LatestQuarter =\n    CALCULATE(\n        MAX('POC Data'[Quarter]),\n        'POC Data'[Year] = SelectedYear\n    )\nRETURN\nCALCULATE(\n    MAX('POC Data'[Net debt]),\n    'POC Data'[Year] = SelectedYear,\n    'POC Data'[Quarter] = LatestQuarter\n)/1000000\n",
          "formatString": "#,##0\" M\"",
          "dataType": "Double",
          "description": "Measures a company's total debt position, factoring in its cash and cash equivalents. It gives an indication of how much debt an airline or aviation company has after accounting for available liquidity.",
          "displayFolder": "",
          "isHidden": false,
          "state": "Ready",
          "outputName": "Net debt"
        },
        {
          "name": "_Cash and cash equivalents",
          "tableName": "POC Data",
          "expression": "\nVAR SelectedYear =\n    MAX('POC Data'[Year])\nVAR LatestQuarter =\n    CALCULATE(\n        MAX('POC Data'[Quarter]),\n        'POC Data'[Year] = SelectedYear\n     )\nRETURN\nCALCULATE(\n    MAX('POC Data'[Cash and cash equivalents]),\n    'POC Data'[Year] = SelectedYear,\n    'POC Data'[Quarter] = LatestQuarter\n)/1000000\n",
          "formatString": "#,##0\" M\"",
          "dataType": "Double",
          "description": "",
          "displayFolder": "",
          "isHidden": false,
          "state": "Ready",
          "outputName": "Cash and cash equivalents"
        },
        {
          "name": "_Net debt/EBITDA",
          "tableName": "POC Data",
          "expression": "\nVAR SelectedYear =\n    MAX('POC Data'[Year])\nVAR LatestQuarter =\n    CALCULATE(\n        MAX('POC Data'[Quarter]),\n        'POC Data'[Year] = SelectedYear\n    )\nRETURN\nCALCULATE(\n    MAX('POC Data'[Net debt/EBITDA]),\n    'POC Data'[Year] = SelectedYear,\n    'POC Data'[Quarter] = LatestQuarter\n)\n",
          "formatString": "\"x \"#,##0.0",
          "dataType": "Double",
          "description": "",
          "displayFolder": "",
          "isHidden": false,
          "state": "Ready",
          "outputName": "Net debt/EBITDA"
        },
        {
          "name": "_%Cash 12m Revenue",
          "tableName": "POC Data",
          "expression": "\nVAR SelectedYear =\n    MAX('POC Data'[Year])\nVAR LatestQuarter =\n    CALCULATE(\n        MAX('POC Data'[Quarter]),\n        'POC Data'[Year] = SelectedYear\n    )\nRETURN\nCALCULATE(\n    MAX('POC Data'[%Cash 12m Revenue]),\n    'POC Data'[Year] = SelectedYear,\n    'POC Data'[Quarter] = LatestQuarter\n)\n",
          "formatString": "0.0 %;-0.0 %;0.0 %",
          "dataType": "Double",
          "description": "",
          "displayFolder": "",
          "isHidden": false,
          "state": "Ready",
          "outputName": "%Cash 12m Revenue"
        },
        {
          "name": "_CASK",
          "tableName": "POC Data",
          "expression": "DIVIDE([_Total Expenditure on Operations],[_ASKs])*100",
          "formatString": "#,##0.00\" c\"",
          "dataType": "Double",
          "description": "Is the sum of the airline's cost values divided by the sum of ASK. Informs on the cost generated by a single passenger's movement per single km",
          "displayFolder": "CASK",
          "isHidden": false,
          "state": "Ready",
          "outputName": "CASK"
        },
        {
          "name": "_Cargo RASK",
          "tableName": "POC Data",
