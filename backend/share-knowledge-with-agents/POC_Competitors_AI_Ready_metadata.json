        {
          "name": "_Margin",
          "tableName": "POC Data",
          "expression": "DIVIDE(CALCULATE(\n        SUM('POC Data'[Total Revenue]) -\n        SUM('POC Data'[Total Expenditure on Operations])\n    ) / 1000000,[_Total Revenue])",
          "formatString": "0.0 %;-0.0 %;0.0 %",
          "dataType": "Double",
          "description": "Profitability ratio that shows the profit that the Opco generates from its core operations in relation with the total revenues.",
          "displayFolder": "",
          "isHidden": false,
          "state": "Ready",
          "outputName": "Margin"
        },
        {
          "name": "_Stage Length",
          "tableName": "POC Data",
          "expression": "CALCULATE(SUM('POC Data'[ASKs])/SUM('POC Data'[Seats]))",
          "formatString": "#,##0\" Km\"",
          "dataType": "Double",
          "description": "Total distance traveled by an aircraft from takeoff to landing for a single flight leg.",
          "displayFolder": "",
          "isHidden": false,
          "state": "Ready",
          "outputName": "Stage Length"
        },
        {
          "name": "_Gauge",
