          "formatString": "#,##0.00\" c\"",
          "dataType": "Double",
          "description": "Is the sum of the airline's cargo revenue values divided by the sum of ASK. Informs on the revenue generated by a single passenger's movement per single km",
          "displayFolder": "",
          "isHidden": false,
          "state": "Ready",
          "outputName": "Cargo RASK"
