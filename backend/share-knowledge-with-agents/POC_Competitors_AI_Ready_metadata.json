          "isHidden": false,
          "state": "Ready",
          "outputName": "Gauge"
        },
        {
          "name": "_Load Factor",
          "tableName": "POC Data",
          "expression": "DIVIDE([_RPKs],[_ASKs])",
          "formatString": "0.0 %;-0.0 %;0.0 %",
          "dataType": "Double",
          "description": "Measures the percentage of available seating capacity that is filled with paying passengers. It indicates how efficiently an airline is utilising its capacity.",
          "displayFolder": "",
          "isHidden": false,
          "state": "Ready",
          "outputName": "Load Factor"
        },
        {
          "name": "_RASK",
          "tableName": "POC Data",
          "expression": "DIVIDE([_Total Revenue],[_ASKs])*100",
          "formatString": "#,##0.00\" c\"",
          "dataType": "Double",
          "description": "Is the sum of the airline's revenue values divided by the sum of ASK. Informs on the revenue generated by a single passenger's movement per single km",
          "displayFolder": "",
          "isHidden": false,
          "state": "Ready",
          "outputName": "RASK"
        },
        {
          "name": "_PRASK",
